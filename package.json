{
  "name": "git-switch",
  "version": "0.2.0",
  "description": "Git identity and SSH key profile switcher for multi-account developers",
  "type": "commonjs",
  "bin": {
    "git-switch": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "compile": "bun build src/index.ts --compile --minify --sourcemap --outfile dist/git-switch",
    "compile:windows": "bun build src/index.ts --compile --minify --sourcemap --target bun-windows-x64 --outfile dist/git-switch",
    "compile:linux": "bun build src/index.ts --compile --minify --sourcemap --target bun-linux-x64 --outfile dist/git-switch",
    "compile:mac-arm": "bun build src/index.ts --compile --minify --sourcemap --target bun-darwin-arm64 --outfile dist/git-switch",
    "compile:mac-x64": "bun build src/index.ts --compile --minify --sourcemap --target bun-darwin-x64 --outfile dist/git-switch",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "db:generate": "drizzle-kit generate",
    "test:installer": "powershell -ExecutionPolicy Bypass -File scripts/test-installer.ps1",
    "test:installer:keep": "powershell -ExecutionPolicy Bypass -File scripts/test-installer.ps1 -KeepInstall"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.0"
  }
}
