{
  "name": "git-switch",
  "version": "0.1.0",
  "description": "Git identity and SSH key profile switcher for multi-account developers",
  "type": "commonjs",
  "bin": {
    "git-switch": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "compile": "bun build src/index.ts --compile --minify --sourcemap --bytecode --outfile dist/git-switch",
    "compile:windows": "bun build src/index.ts --compile --minify --sourcemap --bytecode --target bun-windows-x64 --outfile dist/git-switch",
    "compile:linux": "bun build src/index.ts --compile --minify --sourcemap --bytecode --target bun-linux-x64 --outfile dist/git-switch",
    "compile:mac-arm": "bun build src/index.ts --compile --minify --sourcemap --bytecode --target bun-darwin-arm64 --outfile dist/git-switch",
    "compile:mac-x64": "bun build src/index.ts --compile --minify --sourcemap --bytecode --target bun-darwin-x64 --outfile dist/git-switch",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
